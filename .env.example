# Supabase — Transaction Pooler URL (aus Supabase → Settings → Database → Connection string → Transaction)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT — beliebiger langer zufälliger String (min. 32 Zeichen)
# Generator: openssl rand -hex 32
JWT_SECRET=HIER_ZUFAELLIGEN_STRING_EINTRAGEN

# Webhook-Secret — Make sendet diesen Header zur Authentifizierung
# Authorization: Bearer WEBHOOK_SECRET
WEBHOOK_SECRET=HIER_ZUFAELLIGEN_STRING_EINTRAGEN

# Make — Webhook-URL für Praxedo-Anreicherung (Watch Changes Ersatz)
MAKE_ENRICHMENT_WEBHOOK=https://hook.eu2.make.com/DEIN_WEBHOOK

# App-URL (für Vercel: automatisch gesetzt, lokal manuell)
NEXT_PUBLIC_APP_URL=http://localhost:3000
